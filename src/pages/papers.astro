---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const papers = (await getCollection('papers')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const allTags = [...new Set(papers.flatMap(p => p.data.tags))].sort();
---
<Layout title="Research Papers — OpenLLMStack" description="Curated research papers that shaped the open-source LLM ecosystem: Transformers, FlashAttention, LoRA, and more.">
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <div class="flex items-center gap-2 mb-2">
          <span class="inline-block w-3 h-3 rounded-full bg-rose-500"></span>
          <span class="text-sm font-medium text-rose-400 uppercase tracking-wider">Papers</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4">Research Papers</h1>
        <p class="text-lg text-slate-400 max-w-2xl">The foundational and breakthrough papers driving the open-source LLM revolution.</p>
      </div>

      <div class="flex flex-wrap gap-2 mb-8" id="filter-bar">
        <button class="filter-btn active px-3 py-1.5 rounded-full text-sm font-medium border bg-rose-500/10 text-rose-400 border-rose-500/20 transition-colors" data-tag="all">All</button>
        {allTags.map(tag => (
          <button class="filter-btn px-3 py-1.5 rounded-full text-sm font-medium border border-border-dim bg-surface text-slate-400 hover:bg-surface-alt transition-colors" data-tag={tag}>{tag}</button>
        ))}
      </div>

      <div class="space-y-4" id="card-grid">
        {papers.map((paper) => (
          <a
            href={paper.data.arxivUrl}
            target="_blank"
            rel="noopener"
            class="card-item group block p-6 rounded-xl border border-border-dim bg-surface hover:bg-surface-alt hover:border-rose-500/30 transition-all duration-300"
            data-tags={paper.data.tags.join(',')}
          >
            <div class="flex flex-col sm:flex-row sm:items-start gap-4">
              <div class="flex-1">
                <h2 class="text-lg font-semibold group-hover:text-rose-400 transition-colors mb-2">{paper.data.title}</h2>
                <p class="text-sm text-slate-500 mb-3">{paper.data.authors} &middot; {paper.data.date}</p>
                <p class="text-sm text-slate-400">{paper.data.summary}</p>
              </div>
              <div class="flex flex-wrap sm:flex-col gap-1.5 sm:items-end shrink-0">
                {paper.data.tags.map((tag: string) => (
                  <span class="text-xs px-2 py-0.5 rounded bg-rose-500/10 text-rose-400 border border-rose-500/20">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.card-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => {
        b.classList.remove('active', 'bg-rose-500/10', 'text-rose-400', 'border-rose-500/20');
        b.classList.add('bg-surface', 'text-slate-400');
      });
      btn.classList.add('active', 'bg-rose-500/10', 'text-rose-400', 'border-rose-500/20');
      btn.classList.remove('bg-surface', 'text-slate-400');

      const tag = btn.getAttribute('data-tag');
      cards.forEach(card => {
        if (tag === 'all' || card.getAttribute('data-tags')?.includes(tag!)) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
