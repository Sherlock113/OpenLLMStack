---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const engines = (await getCollection('inference')).sort((a, b) => a.data.name.localeCompare(b.data.name));
const allTags = [...new Set(engines.flatMap(e => e.data.tags))].sort();
---
<Layout title="Inference Engines — OpenLLMStack" description="Compare open-source LLM inference engines: vLLM, SGLang, llama.cpp, Ollama, TGI, TensorRT-LLM, and more.">
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <div class="flex items-center gap-2 mb-2">
          <span class="inline-block w-3 h-3 rounded-full bg-emerald-500"></span>
          <span class="text-sm font-medium text-emerald-400 uppercase tracking-wider">Inference</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4">Inference Engines</h1>
        <p class="text-lg text-slate-400 max-w-2xl">Open-source frameworks for serving and running LLMs — from cloud-scale GPU clusters to local laptops.</p>
      </div>

      <div class="flex flex-wrap gap-2 mb-8" id="filter-bar">
        <button class="filter-btn active px-3 py-1.5 rounded-full text-sm font-medium border bg-emerald-500/10 text-emerald-400 border-emerald-500/20 transition-colors" data-tag="all">All</button>
        {allTags.map(tag => (
          <button class="filter-btn px-3 py-1.5 rounded-full text-sm font-medium border border-border-dim bg-surface text-slate-400 hover:bg-surface-alt transition-colors" data-tag={tag}>{tag}</button>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" id="card-grid">
        {engines.map((engine) => (
          <a
            href={engine.data.url}
            target="_blank"
            rel="noopener"
            class="card-item group p-6 rounded-xl border border-border-dim bg-surface hover:bg-surface-alt hover:border-emerald-500/30 transition-all duration-300"
            data-tags={engine.data.tags.join(',')}
          >
            <div class="flex items-start justify-between mb-4">
              <div>
                <h2 class="text-lg font-semibold group-hover:text-emerald-400 transition-colors">{engine.data.name}</h2>
                <p class="text-sm text-slate-500">{engine.data.org}</p>
              </div>
              <div class="flex items-center gap-1 text-xs text-slate-500">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279-7.416-3.967-7.417 3.967 1.481-8.279-6.064-5.828 8.332-1.151z"/></svg>
                {engine.data.stars}
              </div>
            </div>
            <p class="text-sm text-slate-400 mb-4 line-clamp-3">{engine.data.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {engine.data.tags.map((tag: string) => (
                <span class="text-xs px-2 py-0.5 rounded bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.card-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => {
        b.classList.remove('active', 'bg-emerald-500/10', 'text-emerald-400', 'border-emerald-500/20');
        b.classList.add('bg-surface', 'text-slate-400');
      });
      btn.classList.add('active', 'bg-emerald-500/10', 'text-emerald-400', 'border-emerald-500/20');
      btn.classList.remove('bg-surface', 'text-slate-400');

      const tag = btn.getAttribute('data-tag');
      cards.forEach(card => {
        if (tag === 'all' || card.getAttribute('data-tags')?.includes(tag!)) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
