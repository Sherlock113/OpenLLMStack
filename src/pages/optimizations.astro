---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const optimizations = (await getCollection('optimizations')).sort((a, b) => a.data.name.localeCompare(b.data.name));
---
<Layout title="Inference Optimizations — OpenLLMStack" description="Key techniques for faster, cheaper LLM inference: quantization, attention optimizations, speculative decoding, and more.">
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <div class="flex items-center gap-2 mb-2">
          <span class="inline-block w-3 h-3 rounded-full bg-amber-500"></span>
          <span class="text-sm font-medium text-amber-400 uppercase tracking-wider">Optimizations</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4">Inference Optimizations</h1>
        <p class="text-lg text-slate-400 max-w-2xl">The techniques that make it possible to run powerful LLMs in a more efficient and cost-effective way.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {optimizations.map((opt) => (
          <a
            href={opt.data.url}
            target="_blank"
            rel="noopener"
            class="group p-6 rounded-xl border border-border-dim bg-surface hover:bg-surface-alt hover:border-amber-500/30 transition-all duration-300"
          >
            <h2 class="text-lg font-semibold group-hover:text-amber-400 transition-colors mb-3">{opt.data.name}</h2>
            <p class="text-sm text-slate-400 line-clamp-4">{opt.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
