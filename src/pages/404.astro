---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page not found — OpenLLMStack" description="The page you were looking for doesn't exist. Redirecting you to the homepage.">
  <!-- Fallback redirect for browsers with JS disabled -->
  <meta http-equiv="refresh" content="0;url=/" slot="head" />
  <section class="max-w-2xl mx-auto px-6 py-32 text-center">
    <p class="text-7xl font-extrabold text-blue-400 mb-4">404</p>
    <h1 class="text-2xl font-bold mb-3">Page not found</h1>
    <p class="text-slate-400 mb-8">
      The page you're looking for doesn't exist. Redirecting you to the homepage…
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 rounded-lg bg-blue-500 px-5 py-2.5 font-semibold text-white transition hover:bg-blue-400"
    >
      Go to homepage
    </a>
  </section>
  <script is:inline>
    window.location.replace('/');
  </script>
</Layout>
