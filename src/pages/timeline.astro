---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const events = (await getCollection('timeline')).sort(
  (a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
);

const categoryColors: Record<string, { dot: string; bg: string; text: string; border: string }> = {
  models: { dot: 'bg-blue-500', bg: 'bg-blue-500/10', text: 'text-blue-400', border: 'border-blue-500/20' },
  inference: { dot: 'bg-emerald-500', bg: 'bg-emerald-500/10', text: 'text-emerald-400', border: 'border-emerald-500/20' },
  optimizations: { dot: 'bg-amber-500', bg: 'bg-amber-500/10', text: 'text-amber-400', border: 'border-amber-500/20' },
  agents: { dot: 'bg-purple-500', bg: 'bg-purple-500/10', text: 'text-purple-400', border: 'border-purple-500/20' },
  papers: { dot: 'bg-rose-500', bg: 'bg-rose-500/10', text: 'text-rose-400', border: 'border-rose-500/20' },
  companies: { dot: 'bg-orange-500', bg: 'bg-orange-500/10', text: 'text-orange-400', border: 'border-orange-500/20' },
};

const categories = ['all', 'models', 'inference', 'optimizations', 'agents', 'papers', 'companies'];
---
<Layout title="Timeline — OpenLLMStack" description="An interactive timeline of major milestones in the open source LLM ecosystem.">
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <div class="flex items-center gap-2 mb-2">
          <span class="inline-block w-3 h-3 rounded-full bg-cyan-500"></span>
          <span class="text-sm font-medium text-cyan-400 uppercase tracking-wider">Timeline</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4">Major Milestones</h1>
        <p class="text-lg text-slate-400 max-w-2xl">Key moments that shaped the open source LLM ecosystem.</p>
      </div>

      <div class="flex flex-wrap gap-2 mb-12" id="timeline-filters">
        {categories.map(cat => (
          <button
            class:list={[
              'filter-btn px-3 py-1.5 rounded-full text-sm font-medium border transition-colors',
              cat === 'all'
                ? 'active bg-cyan-500/10 text-cyan-400 border-cyan-500/20'
                : 'bg-surface text-slate-400 border-border-dim hover:bg-surface-alt',
            ]}
            data-category={cat}
          >
            {cat === 'all' ? 'All' : cat.charAt(0).toUpperCase() + cat.slice(1)}
          </button>
        ))}
      </div>

      <div class="relative" id="timeline">
        <div class="absolute left-4 sm:left-1/2 top-0 bottom-0 w-px bg-border-dim sm:-translate-x-px"></div>

        {events.map((event, i) => {
          const colors = categoryColors[event.data.category] ?? categoryColors.models;
          const isLeft = i % 2 === 0;
          return (
            <div class="timeline-event relative flex items-start mb-12 group" data-category={event.data.category}>
              <div class="absolute left-4 sm:left-1/2 -translate-x-1/2 z-10">
                <div class={`w-4 h-4 rounded-full ${colors.dot} ring-4 ring-slate-950 group-hover:ring-slate-900 transition-colors`}></div>
              </div>

              <div class={`ml-12 sm:ml-0 sm:w-[calc(50%-2rem)] ${isLeft ? 'sm:mr-auto sm:pr-8 sm:text-right' : 'sm:ml-auto sm:pl-8'}`}>
                <div class={`inline-block text-xs font-medium px-2.5 py-1 rounded-full ${colors.bg} ${colors.text} border ${colors.border} mb-3`}>
                  {event.data.category}
                </div>
                <time class="block text-sm text-slate-500 mb-2">{event.data.date}</time>
                <h3 class="text-lg font-semibold mb-2">{event.data.title}</h3>
                <p class="text-sm text-slate-400">{event.data.description}</p>
                {event.data.url && (
                  <a href={event.data.url} target="_blank" rel="noopener" class={`inline-flex items-center gap-1 mt-3 text-sm ${colors.text} hover:underline`}>
                    Learn more
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                  </a>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll('#timeline-filters .filter-btn');
  const events = document.querySelectorAll('.timeline-event');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => {
        b.classList.remove('active', 'bg-cyan-500/10', 'text-cyan-400', 'border-cyan-500/20');
        b.classList.add('bg-surface', 'text-slate-400', 'border-border-dim');
      });
      btn.classList.add('active', 'bg-cyan-500/10', 'text-cyan-400', 'border-cyan-500/20');
      btn.classList.remove('bg-surface', 'text-slate-400', 'border-border-dim');

      const category = btn.getAttribute('data-category');
      events.forEach(event => {
        if (category === 'all' || event.getAttribute('data-category') === category) {
          (event as HTMLElement).style.display = '';
        } else {
          (event as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
