---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ModelCard from '../components/ModelCard.astro';

const models = (await getCollection('models')).sort(
  (a, b) => new Date(b.data.releaseDate).getTime() - new Date(a.data.releaseDate).getTime()
);
---
<Layout title="Open Source LLMs — OpenLLMStack" description="A curated directory of open-source large language models: Llama, Mistral, Qwen, DeepSeek, and more.">
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <div class="flex items-center gap-2 mb-2">
          <span class="inline-block w-3 h-3 rounded-full bg-blue-500"></span>
          <span class="text-sm font-medium text-blue-400 uppercase tracking-wider">Models</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4">Open Source LLMs</h1>
        <p class="text-lg text-slate-400 max-w-2xl">The latest and most powerful open language models, from compact edge models to frontier-scale giants.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 max-w-5xl mx-auto">
        {models.map((model) => (
          <ModelCard model={model} />
        ))}
      </div>
    </div>
  </section>
</Layout>
